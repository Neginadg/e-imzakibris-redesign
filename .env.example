# Supabase
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
MAIL_FROM=no-reply@your-domain.com
COMPANY_EMAIL=info@your-domain.com

# Optional PDF attachment sent with application customer confirmation email
# Use a path relative to the project root, or an absolute path on the server
CUSTOMER_ATTACHMENT_PATH=assets/docs/applicationguidelines/dbh_nesue_10_last_clean.pdf

# Multi-line bank account details shown in customer payment email
BANK_ACCOUNT_DETAILS=Banka: Example Bank\nSube: Lefkosa\nIBAN: TR00 0000 0000 0000 0000 0000 00\nHesap Sahibi: Denizler Bilisim Hizmetleri Ltd
